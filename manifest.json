{
  "manifest_version": 3,
  "name": "Codeforces Notes",
  "version": "1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/problemset/problem/*/*",
        "https://codeforces.com/contest/*/problem/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}